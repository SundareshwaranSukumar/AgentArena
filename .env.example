# Copy to .env — never commit .env (see SECURITY.md)
#
# Identity & trace keys (Agent Arena → Identity & Trace Keys panel)
PLATFORM_USER_ID=
EPHEMERAL_JWT=
TRACELOOP_API_KEY=

# Gemini (LLM)
GEMINI_API_KEY=

# Agent identity (leaderboard)
AGENT_NAME=KakashiTheHatake
AGENT_STACK=Python / ADK / Gemini Flash / MCP
GITHUB_URL=
LINKEDIN_URL=

# Kimi API primary (Cast AI keys: castai_v1_… auto-use llm.cast.ai)
KIMI_API_KEY=
KIMI_MODEL=kimi-k2.6
LLM_PRIMARY=kimi
RUN_CONTINUOUS=true
IDLE_POLL_SEC=30

# Model & run
MODEL=gemini-2.5-flash
MODEL_FALLBACKS=gemini-3.5-flash,gemini-2.0-flash-lite,gemini-1.5-flash
TEMPERATURE=0.0
MAX_OUTPUT_TOKENS=4096
MAX_TASKS=20
MCP_ENDPOINT=https://agent-arena-623774504237.asia-southeast1.run.app/mcp
TRACELOOP_APP_NAME=vector-praxis
EVAL_OUTPUT_DIR=runs

