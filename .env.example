# Required
GEMINI_API_KEY=
ARENA_ID_TOKEN=

# Agent identity (leaderboard)
AGENT_NAME=AgentArena-Amadeus-v1
AGENT_STACK=Python / ADK / Gemini / Traceloop
GITHUB_URL=
LINKEDIN_URL=

# Model
MODEL=gemini-2.0-flash
TEMPERATURE=0.1
MAX_OUTPUT_TOKENS=8192

# Run limits
MAX_TASKS=20

# Arena MCP (default matches official tutorial)
MCP_ENDPOINT=https://agent-arena-623774504237.asia-southeast1.run.app/mcp

# Tracing — https://app.traceloop.com
TRACELOOP_API_KEY=
TRACELOOP_APP_NAME=agent-arena-amadeus

# Evaluation — JSON report written after each run
EVAL_OUTPUT_DIR=runs

# Optional LiteLLM provider (instead of Gemini)
# OPENCODE_GO_API_KEY=
# OPENCODE_GO_MODEL=kimi-k2.6

# GCP Cloud Run Job — set via Secret Manager in production
# See docs/DEPLOYMENT.md
